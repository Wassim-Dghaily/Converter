# YallaConvert environment variables (all optional).
# Copy to `.env.local` and fill in to enable. Leaving them empty keeps the site
# completely free of ads and analytics — the consent banner won't even appear in production.

# Google AdSense publisher id — enables ad slots (after a visitor accepts cookies).
# Example: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=

# Plausible analytics domain — enables privacy-friendly analytics (after consent).
# Example: yallaconvert.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
